<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_product_display_price_tag.ProductCard" t-inherit="point_of_sale.ProductCard" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('product-name')]" position="replace">
            <div class="overflow-hidden lh-sm product-name my-2"
                t-att-class="{'d-flex': !props.imageUrl}"
                t-attf-id="article_product_{{props.productId}}"
                t-esc="props.name" style="font-size:14.5px !important;"/>
        </xpath>
        <xpath expr="//div[hasclass('product-content')]" position="before">
            <div class="product-content d-flex flex-row px-2 justify-content-between rounded-bottom rounded-3 flex-shrink-1" style="background-color: #714B67;color: #fff;width: 70%;">
                <t t-esc="env.utils.formatCurrency(props.product.lst_price)"/>
            </div>
        </xpath>
    </t>
</templates>
