<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="ComboButton" owl="1">
        <div class="control-button" t-on-click="_onClickCombo">
            <i class="fa fa-tags"/>
            <span>Apply Combo</span>
        </div>
    </t>

    <t t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension">
        <xpath expr="//div[@class='control-buttons']" position="inside">
            <ComboButton/>
        </xpath>
    </t>

</templates>