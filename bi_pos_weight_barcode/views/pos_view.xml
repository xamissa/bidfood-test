<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="pos_config_settings_item_count">
            <field name="name">res.config.setting.pos.item.form.view</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//setting[@id='customer_display']" position="after">
                    <div id="weight_display" class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                            <field name="pos_is_weight_scale_screen"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="pos_is_weight_scale_screen"/>
                            <div class="text-muted">
                                Create product weight barcode and print. 
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
